# =====================================================================
# RAL CRM — environment template
# Copy to `.env` on the server and fill in real values. NEVER commit `.env`.
# Generate secrets with:  openssl rand -base64 32
# =====================================================================

# ---- Public URL ----------------------------------------------------
# Must match the domain the reverse proxy serves.
SERVER_URL=https://crm.raltech.dev
FRONTEND_URL=https://crm.raltech.dev
# Used by scripts/setup-ssl.sh (nginx site + Let's Encrypt cert). Needs a
# matching nginx/<DOMAIN>.conf file — copy nginx/crm.raltech.dev.conf and
# edit if deploying under a different domain.
DOMAIN=crm.raltech.dev
CERTBOT_EMAIL=info@raltech.dev

# ---- Twenty core ---------------------------------------------------
# APP_SECRET: random 32+ byte secret. REQUIRED.
APP_SECRET=replace_me_with_openssl_rand_base64_32

# Twenty image tag (pin to a release in production, not :latest)
TAG=latest

# ---- PostgreSQL ----------------------------------------------------
PG_DATABASE_USER=twenty
PG_DATABASE_PASSWORD=replace_me_strong_password
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=twenty
# Assembled connection string used by Twenty
PG_DATABASE_URL=postgres://twenty:replace_me_strong_password@db:5432/twenty

# ---- Redis ---------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---- Storage -------------------------------------------------------
# local = on-disk volume (free). Switch to s3 later if needed.
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=.local-storage

# ---- Email (Phase 5 automations + scripts/send_emails.py cold outreach) --
# Fill when wiring SMTP. Left blank = email disabled / send_emails.py stays dry-run.
# Also used directly by scripts/send_emails.py (not just Twenty's own automations).
#   Zoho:  EMAIL_SMTP_HOST=smtp.zoho.com   EMAIL_SMTP_PORT=587 (STARTTLS) or 465 (SSL)
#          App password: Zoho Mail -> Settings -> Security -> App Passwords
#   Gmail: EMAIL_SMTP_HOST=smtp.gmail.com  EMAIL_SMTP_PORT=587
#          App password: https://myaccount.google.com/apppasswords (needs 2FA)
EMAIL_FROM_ADDRESS=info@raltech.dev
EMAIL_FROM_NAME=RAL CRM
EMAIL_SYSTEM_ADDRESS=info@raltech.dev
EMAIL_DRIVER=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# ---- Twenty API (schema build / seed import scripts) ---------------
# Generate in: Settings -> APIs & Webhooks -> Create API Key.
# Used by scripts/phase3_build_schema.py and the Phase 6 import.
TWENTY_URL=http://localhost:3000
TWENTY_API_KEY=
# Google Maps scraper REST API (Phase 4 bridge)
SCRAPER_URL=http://localhost:8080

# ---- Backups -------------------------------------------------------
# How many days of daily Postgres dumps to keep.
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/opt/ral-crm/backups

# Instagram DIY scraper (throwaway account only)
IG_USER=
IG_PASS=
